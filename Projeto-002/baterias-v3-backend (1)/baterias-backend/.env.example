# ══════════════════════════════════════════════
#  CONFIGURAÇÕES DO SISTEMA — copie para .env
# ══════════════════════════════════════════════

# Porta do servidor (padrão: 3000)
PORT=3000

# Segredo para sessões — TROQUE por uma string longa e aleatória!
SESSION_SECRET=TROQUE_ISSO_POR_UMA_CHAVE_SECRETA_LONGA_E_ALEATORIA

# ── E-MAIL (para recuperação de senha) ────────────────────────
# Provedor recomendado: Gmail com Senha de App
# Crie em: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=seuemail@gmail.com
EMAIL_PASS=sua_senha_de_app_aqui
EMAIL_FROM=Baterias Estoque <seuemail@gmail.com>

# URL do sistema (usada nos links de redefinição)
# Desenvolvimento: http://localhost:3000
# Produção: https://seudominio.com.br
APP_URL=http://localhost:3000

# Nome da loja (aparece nos e-mails)
STORE_NAME=Baterias Matheus Juliano

# Ambiente
NODE_ENV=development
